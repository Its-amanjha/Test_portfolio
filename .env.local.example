# Database configuration (Neon connection string)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Vercel Blob storage configuration (Vercel Blob token)
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Authentication Configuration (NextAuth)
# Generate a secret: openssl rand -base64 32
NEXTAUTH_SECRET="some-random-long-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# Admin credentials (used by create-tables script to seed your Neon DB)
ADMIN_EMAIL="aman.your.email@gmail.com"
ADMIN_PASSWORD="ChooseASecurePasswordHere"

# Cache invalidation (Production only)
SITE_URL="https://your-portfolio.vercel.app"
REVALIDATION_SECRET="generate-a-random-token-here"
